{
  "name": "atelier-idea-canvas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check-deps": "node scripts/check-deps.js",
    "tauri": "tauri",
    "tauri:dev": "npm run check-deps && tauri dev",
    "tauri:build": "npm run check-deps && tauri build",
    "launch": "node scripts/launch.js",
    "desktop": "npm run tauri:dev",
    "desktop:build": "npm run tauri:build",
    "postinstall": "node -e \"require('fs').writeFileSync('node_modules/.package-hash', require('crypto').createHash('md5').update(require('fs').readFileSync('package.json')).digest('hex'))\""
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.9.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
